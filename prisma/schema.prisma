generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id   String @id @default(cuid())
  slug String @unique
  name String

  /// Optional comma-separated allowlist of widget origins (e.g. https://dealer.com)
  allowedOrigins String?

  locations     Location[]
  users         User[]
  vehicles      Vehicle[]
  conversations Conversation[]
  leads         Lead[]
  appointments  Appointment[]
  escalations   Escalation[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name    String
  slug    String
  address String?
  phone   String?
  timezone String @default("America/Chicago")

  /// Store hours as JSON: { mon: { open: "09:00", close: "19:00" }, ... }
  storeHours Json?

  inventoryFeedUrl  String?
  inventoryFeedType InventoryFeedType?

  users         User[]
  vehicles      Vehicle[]         @relation("LocationVehicles")
  conversations Conversation[]
  leads         Lead[]
  appointments  Appointment[]
  escalations   Escalation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
}

enum InventoryFeedType {
  XML
  JSON
  CSV
}

model User {
  id String @id @default(cuid())

  email    String
  password String

  firstName String
  lastName  String

  role Role @default(STAFF)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([email])
  @@index([tenantId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
}

model Vehicle {
  id String @id @default(cuid())

  tenantId   String
  locationId String?

  vin   String
  stock String?

  year  Int
  make  String
  model String
  trim  String?

  bodyType     String?
  drivetrain   String?
  transmission String?
  fuelType     String?
  color        String?
  interiorColor String?

  price   Int?
  msrp    Int?
  mileage Int?

  photos   Json?
  features Json?

  status VehicleStatus @default(AVAILABLE)

  /// Provenance: feed source identifier
  source     String?
  lastSeenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location Location? @relation("LocationVehicles", fields: [locationId], references: [id], onDelete: SetNull)

  @@unique([tenantId, vin])
  @@index([tenantId, status])
  @@index([tenantId, make, model])
  @@index([tenantId, price])
  @@index([locationId])
  @@index([stock])
}

enum VehicleStatus {
  AVAILABLE
  IN_TRANSIT
  HOLD
  MISSING
  SOLD
}

model Conversation {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  /// Widget conversationId or staff user id
  externalKey String

  channel ConversationChannel @default(WIDGET)

  /// Serialized ConversationInventoryState
  state Json @default("{}")

  messages     Message[]
  leads        Lead[]
  appointments Appointment[]
  escalations  Escalation[]

  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, externalKey])
  @@index([tenantId, lastActivityAt])
}

enum ConversationChannel {
  WIDGET
  STAFF
  SMS
  EMAIL
}

model Message {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    MessageRole
  content String

  /// Optional structured payload (vehicle cards, payment, etc.)
  metadata Json?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Lead {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  firstName String?
  lastName  String?
  phone     String?
  email     String?
  zipCode   String?

  interestedVin   String?
  interestedStock String?

  budget           Int?
  desiredPayment   Int?
  financingNeeded  Boolean?
  preferredContact String?
  consentToText    Boolean @default(false)
  consentToEmail   Boolean @default(false)

  source  String @default("widget")
  score   Int    @default(0)
  stage   LeadStage @default(COLD)
  status  LeadStatus @default(OPEN)

  assignedUserId String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([conversationId])
}

enum LeadStage {
  COLD
  WARM
  HOT
}

enum LeadStatus {
  OPEN
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
  SPAM
}

model Appointment {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  type AppointmentType @default(SALES)

  /// Customer-requested date (YYYY-MM-DD) — not confirmed availability unless status=CONFIRMED
  requestedDate String?
  requestedTime String?

  /// Verified slot when available from calendar integration
  scheduledAt DateTime?

  status AppointmentStatus @default(REQUESTED)

  customerName  String?
  customerPhone String?
  customerEmail String?

  vehicleVin String?
  notes      String?

  /// False until a human or verified calendar confirms the slot
  availabilityVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
  @@index([conversationId])
}

enum AppointmentType {
  SALES
  SERVICE
  PARTS
  FINANCE
  TEST_DRIVE
}

enum AppointmentStatus {
  REQUESTED
  PENDING_CONFIRMATION
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Escalation {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  reason   String
  urgency  EscalationUrgency @default(NORMAL)
  status   EscalationStatus  @default(OPEN)
  summary  String?
  metadata Json?

  notifiedAt DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([conversationId])
}

enum EscalationUrgency {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum EscalationStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

model RefreshToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// SHA-256 hash of the raw refresh token
  tokenHash String @unique

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id String @id @default(cuid())

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String
  resource String?
  resourceId String?
  metadata Json?
  ip       String?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}
