# Server-only — never expose these via VITE_/NEXT_PUBLIC_ prefixes

# Runtime
NODE_ENV=development
PORT=3000

# PostgreSQL (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/amqur?schema=public

# JWT (required) — JWT_SECRET must be >= 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# Short-lived access tokens (staff)
JWT_EXPIRES_IN=15m
# Refresh token lifetime
JWT_REFRESH_EXPIRES_IN=7d
# Widget JWT lifetime (minted by /api/public/widget-token)
WIDGET_TOKEN_EXPIRES_IN=4h

# CORS — comma-separated origins for production (required in production)
# Leave empty in development to reflect request origin
CORS_ORIGINS=https://dealer.example.com,https://www.dealer.example.com

# One-time bootstrap of first tenant + SUPER_ADMIN via POST /api/auth/bootstrap
# Leave empty to disable bootstrap endpoint
BOOTSTRAP_SECRET=

# Anthropic Claude (optional — polish + intelligent Q&A disabled when empty)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TIMEOUT_MS=25000

# CRM outbound webhook (optional — leads/handoff events)
CRM_WEBHOOK_URL=

# Inventory feed sync cron (every 30m when true)
INVENTORY_SYNC_ENABLED=false
# Comma-separated hostnames allowed for feed fetches (SSRF protection). Empty = any public host (still blocks private IPs).
INVENTORY_FEED_ALLOWED_HOSTS=

# Google Calendar (optional — implemented but not required for chat appointment preference capture)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Integration secret vault (32+ chars) — required before storing Tekion/vAuto credentials
INTEGRATION_ENCRYPTION_KEY=

# Tekion (placeholders only — live disabled until partner credentials + official API docs)
# TEKION_API_BASE_URL=
# TEKION_CLIENT_ID=
# TEKION_CLIENT_SECRET=
# TEKION_WEBHOOK_SECRET=
# TEKION_DEALER_GROUP_ID=
# TEKION_API_VERSION=

# vAuto feed (use Location.inventoryFeedUrl + inventoryFeedType in DB; transport is authorized feed download)
# VAUTO_FEED_TRANSPORT=HTTPS
# VAUTO_EXPECTED_MIN_RECORDS=1
# VAUTO_FRESHNESS_HOURS=24

# Optional Redis (widget-config cache). Outage degrades cache only — never blocks readiness.
REDIS_URL=

# Outbox processor (API process cron). Set false on API replicas when a worker owns processing.
OUTBOX_PROCESSOR_ENABLED=true
OUTBOX_POLL_MS=15000
PROCESS_ROLE=all
