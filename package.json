{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx nest build",
    "build:local": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:cov": "jest --coverage --coverageReporters=text-summary --coverageReporters=lcov --coverageReporters=json-summary",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "test:e2e:platform": "jest --config ./test/jest-e2e.json --runInBand --forceExit --testPathPatterns=suites",
    "test:migration": "jest --config ./test/jest-e2e.json --runInBand --forceExit --testPathPatterns=migration.e2e-spec",
    "test:infra:up": "bash test-infra/scripts/infra-up.sh",
    "test:infra:down": "bash test-infra/scripts/infra-down.sh",
    "test:infra:reset": "bash test-infra/scripts/infra-reset.sh",
    "test:load": "node scripts/load-profiles.mjs",
    "test:soak": "SOAK_MINUTES=30 node scripts/soak.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "start:worker": "node dist/worker.js",
    "seed:staging-pilot": "ts-node --transpile-only scripts/seed-staging-pilot.ts",
    "onboard:dealership": "ts-node --transpile-only scripts/onboard-dealership.ts",
    "test:all:local": "npm run test:infra:reset && set -a && . ./test-infra/.env.test && set +a && npx prisma migrate deploy && npm run typecheck && npm test && npm run test:cov && npm run test:e2e:platform && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^10.66.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "csv-parse": "^6.1.0",
    "fast-xml-parser": "^5.3.3",
    "googleapis": "^170.1.0",
    "ioredis": "^5.11.1",
    "joi": "^18.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^15.15.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0"
  }
}
