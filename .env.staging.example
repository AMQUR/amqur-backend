# Staging pilot environment — placeholders only. Copy to `.env.staging` locally.
# NEVER commit real secrets.

NODE_ENV=production
PORT=3000

# REQUIRED: dedicated STAGING Postgres (do not reuse production)
DATABASE_URL=postgresql://USER:PASSWORD@STAGING_HOST:5432/amqur_staging?schema=public

JWT_SECRET=REPLACE_WITH_STAGING_SECRET_AT_LEAST_32_CHARS_LONG
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
WIDGET_TOKEN_EXPIRES_IN=4h

# Staging CORS — Dial Auto Group test/staging domains only
CORS_ORIGINS=https://staging.example-dealer.com,http://localhost:5173

BOOTSTRAP_SECRET=

# LLM polish optional on staging
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# CRM / Tekion — MUST remain empty/disabled for pilot
CRM_WEBHOOK_URL=

# Inventory: prefer fixture sync off until authorized feed URL is set
INVENTORY_SYNC_ENABLED=false
INVENTORY_FEED_ALLOWED_HOSTS=

# Secret vault (optional until live credentials exist)
INTEGRATION_ENCRYPTION_KEY=

# Google Calendar — leave empty so appointments stay REQUESTED only
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
